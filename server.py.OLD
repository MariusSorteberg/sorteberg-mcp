import os
import logging
from datetime import datetime, timezone
from typing import Any, Dict, List, Tuple

from fastapi import FastAPI, HTTPException, Request
from fastapi.responses import HTMLResponse, JSONResponse, RedirectResponse
from starlette.middleware.sessions import SessionMiddleware

from google.auth.transport.requests import Request as GoogleRequest
from google.oauth2 import id_token as google_id_token
from google.oauth2.credentials import Credentials
from google_auth_oauthlib.flow import Flow
from googleapiclient.discovery import build
from google.cloud import firestore


# -----------------------------------------------------------------------------
# Config
# -----------------------------------------------------------------------------
logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
logger = logging.getLogger(__name__)

BASE_URL = os.environ["BASE_URL"].rstrip("/")
GOOGLE_CLIENT_ID = os.environ["GOOGLE_CLIENT_ID"]
GOOGLE_CLIENT_SECRET = os.environ["GOOGLE_CLIENT_SECRET"]
APP_SECRET = os.environ["APP_SECRET"]  # used to sign session cookie

GOOGLE_REDIRECT_URI = os.getenv(
    "GOOGLE_REDIRECT_URI",
    f"{BASE_URL}/oauth/google/callback"
)

GMAIL_LABEL = os.getenv("GMAIL_LABEL", "merak-group")

# Simple agent auth for now.
# Grok (or your caller) must send:
# Authorization: Bearer <AGENT_BEARER_TOKEN>
AGENT_BEARER_TOKEN = os.getenv("AGENT_BEARER_TOKEN", "")

SCOPES = [
    "openid",
    "email",
    "profile",
    "https://www.googleapis.com/auth/gmail.readonly",
]

TOKEN_COLLECTION = "mcp_config"
TOKEN_DOCUMENT = "gmail_owner"

app = FastAPI()
app.add_middleware(
    SessionMiddleware,
    secret_key=APP_SECRET,
    https_only=True,
    same_site="lax",
)

db = firestore.Client()


# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------
def oauth_client_config() -> Dict[str, Any]:
    return {
        "web": {
            "client_id": GOOGLE_CLIENT_ID,
            "client_secret": GOOGLE_CLIENT_SECRET,
            "auth_uri": "https://accounts.google.com/o/oauth2/auth",
            "token_uri": "https://oauth2.googleapis.com/token",
            "redirect_uris": [GOOGLE_REDIRECT_URI],
        }
    }


def token_doc():
    return db.collection(TOKEN_COLLECTION).document(TOKEN_DOCUMENT)


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def require_agent(request: Request) -> None:
    if not AGENT_BEARER_TOKEN:
        return

    auth = request.headers.get("Authorization", "")
    expected = f"Bearer {AGENT_BEARER_TOKEN}"
    if auth != expected:
        raise HTTPException(status_code=401, detail="Invalid or missing agent bearer token")


def save_owner_tokens(creds: Credentials, user_info: Dict[str, Any]) -> None:
    existing = token_doc().get()
    existing_data = existing.to_dict() if existing.exists else {}

    refresh_token = creds.refresh_token or existing_data.get("refresh_token")
    if not refresh_token:
        raise HTTPException(
            status_code=400,
            detail=(
                "No refresh token returned by Google. "
                "Revoke this app in your Google Account permissions and try again."
            ),
        )

    token_doc().set(
        {
            "google_sub": user_info.get("sub"),
            "email": user_info.get("email", ""),
            "access_token": creds.token,
            "refresh_token": refresh_token,
            "updated_at": now_iso(),
        },
        merge=True,
    )


def get_owner_record() -> Dict[str, Any]:
    snap = token_doc().get()
    if not snap.exists:
        raise HTTPException(
            status_code=403,
            detail="Mailbox owner is not connected yet. Visit /oauth/google/start first.",
        )
    return snap.to_dict()


def get_gmail_service() -> Tuple[Any, Dict[str, Any]]:
    data = get_owner_record()

    creds = Credentials(
        token=data.get("access_token"),
        refresh_token=data.get("refresh_token"),
        token_uri="https://oauth2.googleapis.com/token",
        client_id=GOOGLE_CLIENT_ID,
        client_secret=GOOGLE_CLIENT_SECRET,
        scopes=SCOPES,
    )

    if not creds.valid:
        if creds.expired and creds.refresh_token:
            try:
                creds.refresh(GoogleRequest())
                token_doc().set(
                    {
                        "access_token": creds.token,
                        "updated_at": now_iso(),
                    },
                    merge=True,
                )
            except Exception as e:
                logger.exception("Failed refreshing Gmail token")
                raise HTTPException(status_code=401, detail=f"Failed to refresh Gmail token: {e}")
        else:
            raise HTTPException(status_code=401, detail="Stored Gmail credentials are invalid")

    service = build("gmail", "v1", credentials=creds, cache_discovery=False)
    return service, data


def resolve_label_id(service, label_name: str) -> str:
    labels_resp = service.users().labels().list(userId="me").execute()
    for label in labels_resp.get("labels", []):
        if label.get("name") == label_name:
            return label["id"]
    raise HTTPException(status_code=404, detail=f"Gmail label '{label_name}' not found")


def search_gmail_messages(service, query: str, max_results: int) -> List[Dict[str, Any]]:
    label_id = resolve_label_id(service, GMAIL_LABEL)

    resp = service.users().messages().list(
        userId="me",
        q=(query or "").strip(),
        labelIds=[label_id],
        maxResults=max_results,
        includeSpamTrash=False,
    ).execute()

    messages = []
    for msg in resp.get("messages", []):
        msg_data = service.users().messages().get(
            userId="me",
            id=msg["id"],
            format="metadata",
            metadataHeaders=["From", "Subject", "Date"],
        ).execute()

        headers = {
            h["name"].lower(): h["value"]
            for h in msg_data.get("payload", {}).get("headers", [])
        }

        messages.append(
            {
                "id": msg["id"],
                "from": headers.get("from", ""),
                "subject": headers.get("subject", "No subject"),
                "date": headers.get("date", ""),
                "snippet": msg_data.get("snippet", ""),
            }
        )

    return messages


# -----------------------------------------------------------------------------
# Routes
# -----------------------------------------------------------------------------

# Temporary add Firestore debug route
@app.get("/debug/firestore")
def debug_firestore():
    ref = db.collection("debug").document("ping")
    ref.set({"ok": True, "source": "cloud-run"}, merge=True)
    return {"ok": True, "data": ref.get().to_dict()}


@app.get("/", response_class=HTMLResponse)
def home():
    return f"""
    <html>
      <body style="font-family: sans-serif; max-width: 900px; margin: 40px auto;">
        <h1>📬 Sorteberg MCP</h1>
        <p><b>Base URL:</b> {BASE_URL}</p>
        <ul>
          <li><a href="/healthz">/healthz</a></li>
          <li><a href="/oauth/status">/oauth/status</a></li>
          <li><a href="/oauth/google/start">/oauth/google/start</a></li>
        </ul>
        <p>Configured Gmail label: <b>{GMAIL_LABEL}</b></p>
      </body>
    </html>
    """


@app.get("/healthz")
def healthz():
    return {"ok": True}


@app.get("/oauth/status")
def oauth_status():
    snap = token_doc().get()
    if not snap.exists:
        return {"connected": False, "label": GMAIL_LABEL}

    data = snap.to_dict()
    return {
        "connected": True,
        "email": data.get("email", ""),
        "google_sub": data.get("google_sub", ""),
        "updated_at": data.get("updated_at", ""),
        "label": GMAIL_LABEL,
    }


@app.get("/oauth/google/start")
def oauth_google_start(request: Request):
    flow = Flow.from_client_config(oauth_client_config(), scopes=SCOPES)
    flow.redirect_uri = GOOGLE_REDIRECT_URI

    auth_url, state = flow.authorization_url(
        access_type="offline",
        include_granted_scopes="true",
        prompt="consent",
    )

    request.session["oauth_state"] = state
    return RedirectResponse(auth_url)


@app.get("/oauth/google/callback", response_class=HTMLResponse)
def oauth_google_callback(request: Request):
    state_from_query = request.query_params.get("state")
    state_from_session = request.session.get("oauth_state")

    if not state_from_query or not state_from_session or state_from_query != state_from_session:
        raise HTTPException(status_code=400, detail="Invalid OAuth state")

    flow = Flow.from_client_config(
        oauth_client_config(),
        scopes=SCOPES,
        state=state_from_query,
    )
    flow.redirect_uri = GOOGLE_REDIRECT_URI
    flow.fetch_token(authorization_response=str(request.url))

    creds = flow.credentials
    if not creds.id_token:
        raise HTTPException(status_code=400, detail="Missing ID token from Google response")

    user_info = google_id_token.verify_oauth2_token(
        creds.id_token,
        GoogleRequest(),
        GOOGLE_CLIENT_ID,
    )

    save_owner_tokens(creds, user_info)

    request.session.pop("oauth_state", None)

    return f"""
    <html>
      <body style="font-family: sans-serif; max-width: 900px; margin: 40px auto;">
        <h2>✅ Gmail connected successfully</h2>
        <p><b>Email:</b> {user_info.get("email", "")}</p>
        <p><b>Restricted label:</b> {GMAIL_LABEL}</p>
        <p>You can now call <code>/mcp</code> and the service will use the stored Gmail refresh token automatically.</p>
      </body>
    </html>
    """


@app.post("/")
@app.post("/mcp")
async def mcp(request: Request):
    try:
        body = await request.json()
    except Exception:
        return JSONResponse(
            {
                "jsonrpc": "2.0",
                "id": None,
                "error": {"code": 400, "message": "Invalid JSON body"},
            },
            status_code=400,
        )

    req_id = body.get("id", 1)
    method = body.get("method")
    params = body.get("params", {}) or {}

    try:
        if method == "hello":
            name = params.get("name", "Marius")
            result = f"Hei {name}! Cloud Run + OAuth server is working."

        elif method == "search_gmail":
            require_agent(request)

            query = params.get("query", "")
            max_results = int(params.get("max_results", 5))
            if max_results < 1:
                max_results = 1
            if max_results > 20:
                max_results = 20

            service, owner = get_gmail_service()
            messages = search_gmail_messages(service, query=query, max_results=max_results)

            result = {
                "mailbox_owner": owner.get("email", ""),
                "label": GMAIL_LABEL,
                "count": len(messages),
                "messages": messages,
            }

        else:
            raise HTTPException(status_code=404, detail=f"Unknown method: {method}")

        return JSONResponse(
            {
                "jsonrpc": "2.0",
                "id": req_id,
                "result": result,
            }
        )

    except HTTPException as e:
        return JSONResponse(
            {
                "jsonrpc": "2.0",
                "id": req_id,
                "error": {"code": e.status_code, "message": e.detail},
            },
            status_code=e.status_code,
        )
    except Exception as e:
        logger.exception("Unhandled MCP error")
        return JSONResponse(
            {
                "jsonrpc": "2.0",
                "id": req_id,
                "error": {"code": 500, "message": str(e)},
            },
            status_code=500,
        )
